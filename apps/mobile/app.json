{
  "expo": {
    "name": "Colibri Chat",
    "slug": "colibri-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.colibrichat.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Colibri Chat uses your location to find nearby rooms and verify you are within the geofence.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Colibri Chat uses your location to maintain your presence in chat rooms.",
        "UIBackgroundModes": ["location", "fetch"]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.colibrichat.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Colibri Chat uses your location to maintain your presence in chat rooms."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      ["expo-screen-capture", {}]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
